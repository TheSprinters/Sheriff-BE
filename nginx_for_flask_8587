server {
    listen 80;
    listen [::]:80;
    server_name sheriff.opencodingsociety.com;

    # Proxy Socket.IO connections to 8500
    location /socket.io/ {
        proxy_pass http://localhost:8500;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Proxy all other traffic to Flask — let Flask-CORS handle all CORS headers
    location / {
        proxy_pass http://localhost:8325;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        #  No CORS headers here — Flask-CORS handles it
    }
}